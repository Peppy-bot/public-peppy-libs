// This is an example of a configuration of a node that is supposed to be depoyed in a non-std environement
// no_std environenments will be a bit particular so we'll need a "peppylib_no_std" version of "peppylib".
// This lib will allow topics/actions/services creation/polling
{
  peppy_schema: "node/v1",
  manifest: {
    // Here we assume a XIAO ESP32-C3 board connected to a servo and responsible for controlling it 
    name: "esp32_board",
    tag: "v1",
    labels: [
      "no_std",
      "STS3XIAO",
      "ESP32",
      "STS3XIAO_ESP32C3215"
    ],
  },
  interfaces: {
    // `peppylib_no_std` will help expose this topic
    topics: {
      emits: [
        {
          name: "actuator",
          qos_profile: "sensor_data",
          message_format: {
            header: {
              $type: "object",
              stamp: "time",
              actuator_id: "u32"
            },
            command: "string", // e.g., "set_position", "toggle", "set_pwm"
            value: "float", // e.g., position, speed, duty cycle
            status: "string", // "ok", "error", "busy"
            feedback: {
              $type: "object",
              position: "float", // Actual measured position (if available)
              current: "float", // Current consumption (if available)
            }
          }
        }
      ],
    },
  },
  execution: {
    language: "rust",
    run_cmd: [
      // This programs compiles and flashes the program to the board
      "espflash",
      "flash",
      "--compile",
      // The heap doesn't exist in no_std envs, so this flag need to be set at compilation time
      // The parsing of the json5 config can eventually be done on the host and passed down to the `espflash` program
      "--peppy-execution-config",
      "${PEPPY_RUNTIME_CONFIG}",
      "--to_device",
      "${ESP32_DEVICE}" // This is an extra var that can be defined in the deployments
    ]
  },
}