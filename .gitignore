# ---------------------------------------------------------------------------
# Rust
# ---------------------------------------------------------------------------
# Build artifacts (Cargo build directory, present per-workspace/-crate).
target/

# Backtraces emitted on panic.
*.rs.bk

# Cargo.lock is committed for binaries and ignored for libraries; leave the
# decision to each subproject and do not ignore it globally.

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files.
__pycache__/
*.py[cod]
*$py.class
.pixi

# C extensions.
*.so

# Distribution / packaging.
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

