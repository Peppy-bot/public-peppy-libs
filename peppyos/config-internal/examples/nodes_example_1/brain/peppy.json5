// A simple node that has an AI and acts as the brain of the robot.
// It receives camera data and sends actions to the controller.
{
  peppy_schema: "node_v1",
  manifest: {
    name: "brain",
    tag: "v1",
    labels: [
      "brain"
    ],
    depends_on: {
      nodes: [
        {
          name: "uvc_camera",
          tag: "v1",
          link_id: "uvc_camera"
        },
        {
          name: "controller",
          tag: "v1",
          link_id: "controller"
        },
      ]
    },
  },
  interfaces: {
    topics: {
      consumes: [
        {
          link_id: "uvc_camera",
          name: "video_stream",
        }
      ],
    },
    services: {
      consumes: [
        {
          link_id: "uvc_camera",
          name: "video_stream_info",
        }
      ],
    },
    actions: {
      consumes: [
        {
          link_id: "controller",
          name: "move_right_arm",
        },
        {
          link_id: "controller",
          name: "move_left_arm",
        }
      ],
    },
  },
  execution: {
    language: "rust",
    build_cmd: [
      "cargo",
      "build",
      "--release"
    ],
    run_cmd: [
      "./target/release/brain"
    ]
  },
}