// A simple node that receives commands from a brain and control the joints of the robot
{
  peppy_schema: "node_v1",
  manifest: {
    name: "controller",
    tag: "v1",
    labels: [
      "controller",
      "openarm",
    ],
  },
  interfaces: {
    actions: {
      exposes: [
        {
          // The controller exposes this action to the brain
          name: "move_right_arm",
          goal_service: {
            request_message_format: {
              arm_id: "u16",
              desired_position: {
                $type: "array",
                $items: "i32",
                $length: 3
              }
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          feedback_topic: {
            qos_profile: "standard", // Options: "standard", "reliable", "sensor_data"
            message_format: {
              current_position: {
                $type: "array",
                $items: "i32",
                $length: 3
              }
            }
          },
          // Always using "reliable" qos
          result_service: {
            response_message_format: {
              final_position: {
                $type: "array",
                $items: "i32",
                $length: 3
              }
            }
          }
        },
        {
          // The controller exposes this action to the brain
          name: "move_left_arm",
          goal_service: {
            request_message_format: {
              arm_id: "u16",
              desired_position: {
                $type: "array",
                $items: "i32",
                $length: 3
              }
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          feedback_topic: {
            qos_profile: "standard", // Options: "standard", "reliable", "sensor_data"
            message_format: {
              current_position: {
                $type: "array",
                $items: "i32",
                $length: 3
              }
            }
          },
          // Always using "reliable" qos
          result_service: {
            response_message_format: {
              final_position: {
                $type: "array",
                $items: "i32",
                $length: 3
              }
            }
          }
        }
      ],
    },
  },
  execution: {
    language: "rust",
    build_cmd: [
      "cargo",
      "build",
      "--release"
    ],
    run_cmd: [
      "./target/release/controller"
    ]
  },
}