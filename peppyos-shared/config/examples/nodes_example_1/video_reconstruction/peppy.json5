{
  peppy_schema: "node_v1",
  manifest: {
    name: "video_reconstruction",
    tag: "v1",
    depends_on: {
      nodes: [
        {
          name: "uvc_camera",
          tag: "v1",
          link_id: "uvc_camera"
        },
      ]
    },
  },
  interfaces: {
    topics: {
      consumes: [
        {
          link_id: "uvc_camera",
          name: "video_stream",
        },
      ],
    },
    services: {
      consumes: [
        {
          link_id: "uvc_camera",
          name: "video_stream_info",
        },
      ],
    },
  },
  execution: {
    language: "rust",
    parameters: {
      // How long do you want the reconstruction to be?
      video_duration_seconds: "u32"
    },
    container: {
      def_file: "apptainer.def",
      mount_paths: [
        // host_path:container_path:options
        "/tmp/video_reconstruction:/tmp/video_reconstruction:rw"
      ]
    }
  },
}