// A simple node that emits video frames from a UVC camera
{
  peppy_schema: "node_v1",
  manifest: {
    name: "uvc_camera",
    tag: "v1",
    // Labels are useful if the node is published with `peppy node publish`
    labels: [
      "uvc",
      "camera",
      "usb",
    ],
  },
  interfaces: {
    topics: {
      emits: [
        {
          name: "video_stream",
          qos_profile: "sensor_data",
          message_format: {
            header: {
              $type: "object",
              stamp: "time",
              frame_id: "u32",
            },
            encoding: "string", // "rgb8", "bgr8", "yuyv", "mjpeg"
            width: "u32",
            height: "u32",
            frame: {
              $type: "array",
              $items: "u8",
            },
          },
        }
      ],
    },
    services: {
      exposes: [
        {
          name: "enable_camera",
          request_message_format: {
            enable: "bool",
          },
        },
        {
          // This service simply returns camera info; no request body is required.
          name: "video_stream_info",
          response_message_format: {
            width: "u32",
            height: "u32",
            frames_per_second: "u8",
            encoding: "string",
          },
        },
      ],
    },
  },
  execution: {
    language: "rust",
    // Expected parameter types to start the node
    parameters: {
      device: {
        // Can be USB IDs/serial or udev rule
        path: {
          $type: "string",
          $default: "/dev/video0"
        },
      },
      video: {
        frame_rate: {
          $type: "u16",
          $default: 30
        },
        resolution: {
          width: "u16",
          height: "u16",
        },
        encoding: "string", // "rgb8", "bgr8", "yuyv", "mjpeg"
      },
    },
    container: {
      def_file: "apptainer.def"
    }
  },
}