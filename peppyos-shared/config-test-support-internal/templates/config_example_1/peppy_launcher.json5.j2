{
  deployments: [
    {
      source: {
        repo: "{{ lidar_sensor_github_repo }}",
        path: "{{ lidar_sensor_github_repo_path }}",
        ref: "{{ lidar_sensor_github_ref }}"
      },
      instances: [
        {
          instance_id: "lidar_1",
          arguments: {
            device: {
              physical: "/dev/lidar1",
              sim: "mujoco:lidar1",
              priority: "sim"
            },
            lidar_point: {
              x: 12.34, // meters, X coordinate in 3D space
              y: -7.56, // meters, Y coordinate in 3D space
              z: 1.23, // meters, Z coordinate in 3D space (height)
              intensity: 0.85, // normalized intensity of return signal (0 to 1)
              return_type: 1, // e.g. 1 = first return, 2 = last return
              classification: 2, // e.g. 2 = ground, 5 = vegetation
              timestamp: 1696285145999, // Unix timestamp in milliseconds
            }
          }
        }
      ]
    },
    {
      source: {
        repo: "{{ uvc_camera_github_repo }}",
        path: "{{ uvc_camera_github_repo_path }}",
        ref: "0.1.0"
      },
      instances: [
        {
          instance_id: "camera_right",
          arguments: {
            device: {
              physical: "/dev/video_right",
              sim: "mujoco:camera_right",
              priority: "physical"
            },
            video: {
              frame_rate: 30,
              resolution: {
                width: 1920,
                height: 1080,
              },
              encoding: "yuyv",
            },
          }
        },
        {
          instance_id: "camera_left",
          arguments: {
            device: {
              physical: "/dev/video_left",
              sim: "mujoco:camera_left",
              priority: "physical"
            },
            video: {
              frame_rate: 30,
              resolution: {
                width: 1920,
                height: 1080,
              },
              encoding: "yuyv",
            },
          }
        }
      ]
    },
    // `web_video_stream` depends on `uvc_camera`
    {
      source: { local: "./{{ web_video_stream_node_name }}" },
      instances: [
        {
          instance_id: "stream_1",
          arguments: {
            http: {
              host: "0.0.0.0",
              port: 8083,
              cors_enabled: false,
              cors_origins: "*",
              max_connections: 2000,
              request_timeout_ms: 3000,
            },
            video_stream: {
              format: "mjpeg",
              quality: 3,
              max_fps: 30,
            },
          }
        }
      ]
    },
    {
      source: { local: "./{{ brain_node_name }}" },
      instances: [
        {
          instance_id: "the_brain",
          arguments: {}
        }
      ],
    },
    {
      source: { local: "./{{ controller_node_name }}" },
      instances: [
        {
          instance_id: "the_nervous_system",
          arguments: {}
        }
      ]
    },
  ]
}
